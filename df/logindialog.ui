    /* Styles for the new links */
    QPushButton#forgotBtn, QPushButton#registerBtn {
        background-color: transparent;
        color: #94a3b8;
        border: none;
        font-size: 11px;
        text-decoration: none;
    }
    QPushButton#forgotBtn:hover, QPushButton#registerBtn:hover {
